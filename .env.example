# ResilienceOps Environment Configuration
# Copy this file to .env and fill in your actual values

# Required: API endpoint for the LLM
# Examples:
#   - Hugging Face: https://router.huggingface.co/v1
#   - OpenAI: https://api.openai.com/v1
#   - Local: http://localhost:8000/v1
API_BASE_URL=https://router.huggingface.co/v1

# Required: Model identifier for inference
# Examples:
#   - Hugging Face: Qwen/Qwen2.5-72B-Instruct
#   - OpenAI: gpt-4
#   - Local: meta-llama/Llama-3.2-3B-Instruct
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Required: API key for authentication
# For Hugging Face: Get your token from https://huggingface.co/settings/tokens
# For OpenAI: Get your key from https://platform.openai.com/api-keys
# Can also use HF_TOKEN alias (both work)
HF_TOKEN=your_hf_token_here
# API_KEY=your_api_key_here  # Alternative name

# Optional: Environment server URL (for local development)
ENV_BASE_URL=http://localhost:8000

# Optional: Benchmark name
RESILIENCE_OPS_BENCHMARK=resilience_ops_env
